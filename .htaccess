# ══════════════════════════════════════════════════════════════
#  .htaccess — Compra y Listo
# ══════════════════════════════════════════════════════════════

# ── Configuración de Rutas ──────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteRule ^config/  - [F,L]
    RewriteRule ^vendor/  - [F,L]
</IfModule>

# ── Bloquear archivos sensibles ───────────────────────────────
<FilesMatch "\.(env|log|sh|sql|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ══════════════════════════════════════════════════════════════
#  RENDIMIENTO — Compresión Gzip
# ══════════════════════════════════════════════════════════════
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff2
    AddOutputFilterByType DEFLATE font/woff
    # Ignorar navegadores rotos
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# ══════════════════════════════════════════════════════════════
#  RENDIMIENTO — Caché del navegador
# ══════════════════════════════════════════════════════════════
<IfModule mod_expires.c>
    ExpiresActive On
    # Imágenes: 1 mes
    ExpiresByType image/jpeg        "access plus 1 month"
    ExpiresByType image/png         "access plus 1 month"
    ExpiresByType image/gif         "access plus 1 month"
    ExpiresByType image/webp        "access plus 1 month"
    ExpiresByType image/svg+xml     "access plus 1 month"
    ExpiresByType image/x-icon      "access plus 1 year"
    # CSS y JS: 1 semana
    ExpiresByType text/css          "access plus 1 week"
    ExpiresByType text/javascript   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    # Fuentes: 1 mes
    ExpiresByType font/woff2        "access plus 1 month"
    ExpiresByType font/woff         "access plus 1 month"
    ExpiresByType font/ttf          "access plus 1 month"
    # HTML/PHP: sin caché (contenido dinámico)
    ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ── Cache-Control para recursos estáticos ───────────────────
<FilesMatch "\.(ico|jpg|jpeg|png|gif|webp|svg)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
</FilesMatch>
<FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=604800"
</FilesMatch>
<FilesMatch "\.(woff2|woff|ttf)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
</FilesMatch>

# ══════════════════════════════════════════════════════════════
#  RENDIMIENTO — Keep-Alive y ETags
# ══════════════════════════════════════════════════════════════
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>
# ETags: desactivar inode para servidores distribuidos
FileETag MTime Size

# ══════════════════════════════════════════════════════════════
#  RENDIMIENTO — Encoding
# ══════════════════════════════════════════════════════════════
AddDefaultCharset UTF-8
